{
    "buttons": [
        {
            "label": "lock",
            "action": "/home/mich/bin/mich-lock.sh",
            "text": "Lock",
            "keybind": "l",
            "icon": "/usr/share/wleave/icons/lock.svg"
        },
        {
            "label": "suspend",
            "action": "/home/mich/bin/mich-lock.sh suspend",
            "text": "Suspend",
            "keybind": "u",
            "icon": "/usr/share/wleave/icons/suspend.svg"
        },
        {
            "label": "logout",
            "action": "swaymsg exit",
            "text": "Logout",
            "keybind": "e",
            "icon": "/usr/share/wleave/icons/logout.svg"
        },
        {
            "label": "shutdown",
            "action": "systemctl poweroff",
            "text": "Shutdown",
            "keybind": "s",
            "icon": "/usr/share/wleave/icons/shutdown.svg"
        },
        {
            "label": "reboot",
            "action": "systemctl reboot",
            "text": "Reboot",
            "keybind": "r",
            "icon": "/usr/share/wleave/icons/reboot.svg"
        }
    ]
}
